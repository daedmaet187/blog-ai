# Core
APP_ENV=production
DATABASE_URL=postgresql://user:pass@host:5432/blogdb
REDIS_URL=redis://host:6379/0

# Auth
JWT_SECRET=change-me
JWT_ACCESS_TOKEN_MINUTES=120

# Wayl
WAYL_BASE_URL=https://api.wayl.io
WAYL_API_KEY=replace-with-wayl-api-key
WAYL_WEBHOOK_SECRET=replace-with-wayl-webhook-secret

# GitHub provisioning
GITHUB_TOKEN=replace-with-github-token
GITHUB_OWNER=your-org-or-username
GITHUB_REPO_PREFIX=lp

# Optional deployment defaults
DEFAULT_PREVIEW_BASE_URL=https://preview.local
DEFAULT_PROD_BASE_URL=https://sites.yourdomain.com
